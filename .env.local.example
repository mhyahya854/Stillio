## Copy this file to .env.local and fill values (do NOT commit .env.local)

# Google OAuth Client ID and Secret (from Google Cloud Console)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# A random long secret used to sign session cookies (keep private)
AUTH_SECRET=

# The URL where the auth server runs (must match OAuth redirect URI)
AUTH_URL=http://localhost:3000

# Optional: client app origin used for CORS - Vite dev server
CLIENT_ORIGIN=http://localhost:8080

# Optional: expose server URL to the frontend via Vite env var
VITE_AUTH_URL=http://localhost:3000
